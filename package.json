{
  "name": "state-clone",
  "version": "1.0.0",
  "description": "A clone of the U.S. State Department's Smart Traveler Enrollment Program (STEP)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "setup": "npm run migrate && npm run seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "load-test": "node scripts/loadTest.js",
    "health": "node scripts/healthCheck.js",
    "health:verbose": "node scripts/healthCheck.js --verbose",
    "logs": "tail -f logs/combined.log",
    "docker:up": "docker-compose -f docker-compose-local.yml up -d",
    "docker:down": "docker-compose -f docker-compose-local.yml down",
    "docker:build": "docker-compose -f docker-compose-local.yml build",
    "docker:logs": "docker-compose -f docker-compose-local.yml logs -f app",
    "docker:restart": "docker-compose -f docker-compose-local.yml restart app",
    "docker:clean": "docker-compose -f docker-compose-local.yml down -v --remove-orphans",
    "docker:tools": "docker-compose -f docker-compose-local.yml --profile tools up -d pgadmin redis-commander"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.15.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "faker": "^5.5.3",
    "firebase-admin": "^10.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.2",
    "pg": "^8.11.3",
    "twilio": "^4.19.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "travel",
    "alerts",
    "sms",
    "notifications",
    "step",
    "state-department"
  ],
  "author": "",
  "license": "MIT"
}

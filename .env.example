# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/step_clone

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Redis Configuration (for BullMQ)
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=3000
NODE_ENV=development

# API Base URL (for health checks and testing)
API_BASE_URL=http://localhost:9999

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3001

# Logging Configuration
LOG_LEVEL=info

# External APIs (Optional - for enhanced features)
# US State Department Travel Advisories API
STATE_DEPT_API_BASE=https://www.state.gov/wp-json/wp/v2

# OpenWeather API for weather-related travel alerts
OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Alternative: REST Countries API for country information
REST_COUNTRIES_API_URL=https://restcountries.com/v3.1

# Email Configuration (Optional)
# Option 1: Gmail (easier setup)
EMAIL_SERVICE=gmail
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Option 2: General SMTP (more flexible)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-smtp-password

# Email sender address
FROM_EMAIL=noreply@stepclone.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100